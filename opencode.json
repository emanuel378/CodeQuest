{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "instructions": ["AGENTS.md", "DESIGN.md"],
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "mcp-fetch-server", "."]
    }
  }
}