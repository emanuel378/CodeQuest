{
  "$schema": "https://opencode.ai/config.json",
  "shell": "pwsh",
  "instructions": ["AGENTS.md", "DESIGN.md"],
  "mcp": {
    "stitch": {
      "type": "local",
      "command": ["npx", "-y", "@_davideast/stitch-mcp", "proxy"],
      "environment": {
        "STITCH_USE_SYSTEM_GCLOUD": "1"
      },
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true
    }
  }
}
